# ==========================================
# 📦 PyInstaller & Сборка EXE (Специфично для проекта)
# ==========================================
# Исключаем временные файлы компиляции исполняемого файла
build/
dist/
*.spec

# Логи и история матчей, которые генерируются локально при тестах
history.txt
*.log

# ==========================================
# 🐍 Кэш и временные файлы Python
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
.env
.venv

# ==========================================
# 🎮 Специфичный кэш Ursina Engine / Panda3D
# ==========================================
# Исключаем файлы конфигурации движка, если они создаются локально
*.prc
.ursina/

